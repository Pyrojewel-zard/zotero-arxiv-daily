# Zotero
ZOTERO_ID=           # 你的 Zotero 用户 ID（纯数字，从 https://www.zotero.org/settings/security 获取）
ZOTERO_KEY=          # Zotero API 密钥（需 read 权限，从同一页面生成）

# Email SMTP
SENDER=              # 发件邮箱地址，如 abc@qq.com
SENDER_PASSWORD=     # SMTP 授权码（非邮箱登录密码）
RECEIVER=            # 收件邮箱地址

# LLM API
OPENAI_API_KEY=      # LLM API Key，如 sk-xxx
OPENAI_API_BASE=     # LLM API 地址，如 https://api.siliconflow.cn/v1
OPENAI_MODEL=        # LLM 模型名称，如 gpt-4o-mini（留空则默认 gpt-4o-mini）

# Debug（可选，留空则不启用）
DEBUG=
